# Puerto del servidor
PORT=3000

# Secreto de sesión: pon una cadena aleatoria larga
SESSION_SECRET=pon-aqui-una-cadena-aleatoria

# SuperAdministrador (panel en /admin): genera códigos de invitación y gestiona
# usuarios (más días de uso, más espacio, eliminar cuentas). Sin estas dos
# variables el panel queda desactivado (responde 404). Usa una contraseña larga.
# SUPERADMIN_USER=admin
# SUPERADMIN_PASSWORD=pon-aqui-una-contrasena-larga

# URL pública del servicio (OBLIGATORIA). Es la base de todos los enlaces que
# el servidor envía por email (recuperación de contraseña, código de la compra,
# aviso de caducidad) y del QR del evento. Nunca se deduce de la petición: si se
# dedujera, un atacante podría falsear la cabecera Host y desviar el enlace de
# recuperación —con su token— a su propio servidor. En local usa la de abajo.
PUBLIC_URL=http://localhost:3000
# En producción, tu dominio real:
# PUBLIC_URL=https://fotos.tudominio.com

# Límites de subida
# Por archivo. 25 MB cubre cualquier foto de móvil; súbelo si esperas
# originales de cámara.
MAX_FILE_MB=25
# Tope de una petición completa (todos los archivos de un envío juntos).
MAX_REQUEST_MB=200
# Cuota por evento: evita que un solo evento acapare todo el disco.
MAX_TOTAL_GB=5
# Tope global de todos los eventos juntos. Opcional: sin definir, el límite se
# calcula solo a partir del espacio libre real del disco, así que ampliar el
# disco del servidor se refleja al momento (barra del panel y subidas) sin
# reiniciar. Con una cifra, actúa como techo fijo por debajo de ese cálculo.
# MAX_GLOBAL_GB=15
# Franja del disco que las fotos nunca ocupan (modo automático), para que el
# sistema (logs, actualizaciones) no se quede sin sitio.
# DISK_RESERVE_GB=2

# Compresión de imágenes
IMAGE_MAX_SIDE=2560
IMAGE_QUALITY=82

# Envío de emails de recuperación de contraseña (SMTP). Sin configurar,
# el correo se imprime en el log del servidor en vez de enviarse (útil en local).
# Ejemplo con Gmail: host smtp.gmail.com, puerto 587, y una contraseña de aplicación
# (no la contraseña normal de la cuenta) en SMTP_PASS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tuapp@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=tuapp@gmail.com

# Buzón donde llegan los mensajes del formulario de contacto de la landing.
# Sin definir, se usa SMTP_USER; sin SMTP, el mensaje se imprime en el log.
# CONTACT_EMAIL=tucorreo@gmail.com

# Compra directa con Stripe (opcional). Con las DOS claves definidas, la landing
# vende los planes con pago con tarjeta y el comprador recibe su código de
# invitación por email (configura también el SMTP de arriba). Sin ellas, la
# contratación sigue siendo por el formulario de contacto.
# - STRIPE_SECRET_KEY: clave secreta de la API (sk_live_... o sk_test_...),
#   en https://dashboard.stripe.com/apikeys
# - STRIPE_WEBHOOK_SECRET: secreto de firma (whsec_...) del webhook apuntando a
#   https://tu-dominio/api/stripe/webhook con los eventos
#   checkout.session.completed y checkout.session.async_payment_succeeded,
#   en https://dashboard.stripe.com/webhooks
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
