# Puerto del servidor
PORT=3000

# Secreto de sesión: pon una cadena aleatoria larga
SESSION_SECRET=pon-aqui-una-cadena-aleatoria

# SuperAdministrador (panel en /admin): genera códigos de invitación y gestiona
# usuarios (más días de uso, más espacio, eliminar cuentas). Sin estas dos
# variables el panel queda desactivado (responde 404). Usa una contraseña larga.
# SUPERADMIN_USER=admin
# SUPERADMIN_PASSWORD=pon-aqui-una-contrasena-larga

# URL pública a la que apuntan los códigos QR (opcional; por defecto usa la del propio servidor)
# PUBLIC_URL=https://fotos.tudominio.com

# Límites de subida
MAX_FILE_MB=100
# Cuota por evento: evita que un solo evento acapare todo el disco.
MAX_TOTAL_GB=5
# Tope global de todos los eventos juntos. Opcional: sin definir, el límite se
# calcula solo a partir del espacio libre real del disco, así que ampliar el
# disco del servidor se refleja al momento (barra del panel y subidas) sin
# reiniciar. Con una cifra, actúa como techo fijo por debajo de ese cálculo.
# MAX_GLOBAL_GB=15
# Franja del disco que las fotos nunca ocupan (modo automático), para que el
# sistema (logs, actualizaciones) no se quede sin sitio.
# DISK_RESERVE_GB=2

# Compresión de imágenes
IMAGE_MAX_SIDE=2560
IMAGE_QUALITY=82

# Envío de emails de recuperación de contraseña (SMTP). Sin configurar,
# el correo se imprime en el log del servidor en vez de enviarse (útil en local).
# Ejemplo con Gmail: host smtp.gmail.com, puerto 587, y una contraseña de aplicación
# (no la contraseña normal de la cuenta) en SMTP_PASS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tuapp@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=tuapp@gmail.com

# Buzón donde llegan los mensajes del formulario de contacto de la landing.
# Sin definir, se usa SMTP_USER; sin SMTP, el mensaje se imprime en el log.
# CONTACT_EMAIL=tucorreo@gmail.com
