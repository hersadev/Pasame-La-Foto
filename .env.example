# Puerto del servidor
PORT=3000

# Credenciales del administrador
ADMIN_EMAIL=admin@example.com
# Hash bcrypt de la contraseña, en base64 (así el "$" del hash no choca con
# la sustitución de variables que hace docker-compose al leer env_file).
# Genera uno con:
# node -e "console.log(Buffer.from(require('bcryptjs').hashSync('tu-contraseña', 12)).toString('base64'))"
ADMIN_PASSWORD_HASH_B64=

# Secreto de sesión: pon una cadena aleatoria larga
SESSION_SECRET=pon-aqui-una-cadena-aleatoria

# URL pública a la que apunta el código QR (opcional; por defecto usa la del propio servidor)
# PUBLIC_URL=https://fotos.tudominio.com

# Límites de subida
MAX_FILE_MB=100
MAX_TOTAL_GB=20

# Compresión de imágenes
IMAGE_MAX_SIDE=2560
IMAGE_QUALITY=82
