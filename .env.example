# Puerto del servidor
PORT=3000

# Secreto de sesión: pon una cadena aleatoria larga
SESSION_SECRET=pon-aqui-una-cadena-aleatoria

# URL pública a la que apuntan los códigos QR (opcional; por defecto usa la del propio servidor)
# PUBLIC_URL=https://fotos.tudominio.com

# Límites de subida
MAX_FILE_MB=100
# Cuota por evento: evita que un solo evento acapare todo el disco.
MAX_TOTAL_GB=5
# Tope global de todos los eventos juntos. Ponlo por debajo del disco real
# (p.ej. 13 para un disco de 15 GB) para dejar holgura: una petición en curso
# puede rebasar el tope hasta MAX_FILE_MB x nº de archivos antes de rechazarse.
MAX_GLOBAL_GB=15

# Compresión de imágenes
IMAGE_MAX_SIDE=2560
IMAGE_QUALITY=82
